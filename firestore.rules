rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // A signed-in user may read/write only their own subtree.
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Shared, read-only config (catalog, slate seed) — written out-of-band.
    // Tightened/extended in later phases (P3 catalog, P4 slate).
    match /config/{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Shared player catalog (`catalog/current`): world-readable so the app can
    // load it pre-auth/offline; authored via console/CI only.
    match /catalog/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Shared leaderboard: anyone signed in may read; a player may write only
    // their own entry (doc id == their uid). No validation of the points value
    // yet (anti-cheat is a later hardening pass).
    match /leaderboard/{entryUid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == entryUid;
    }
  }
}
